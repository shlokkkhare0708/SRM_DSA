/* 1. Grade Calculator */
#include <stdio.h>
#include <limits.h>

void gradeCalculator() {
    int marks;

    printf("Enter Marks: ");
    scanf("%d", &marks);

    if (marks >= 40 && marks <= 49)
        printf("Grade: D\n");
    else if (marks >= 50 && marks <= 59)
        printf("Grade: D+\n");
    else if (marks >= 60 && marks <= 69)
        printf("Grade: C\n");
    else if (marks >= 70 && marks <= 75)
        printf("Grade: C+\n");
    else if (marks >= 76 && marks <= 80)
        printf("Grade: B+\n");
    else if (marks >= 81 && marks <= 96)
        printf("Grade: A\n");
    else if (marks > 96)
        printf("Grade: A+\n");
    else
        printf("Fail\n");
}

/* 2. Pattern 1 */
void pattern1() {
    int i, j;

    for (i = 1; i <= 5; i++) {
        for (j = 1; j <= 5; j++) {
            printf("* ");
        }
        printf("\n");
    }
}

/* 3. Pattern 2 */
void pattern2() {
    int i, j;

    for (i = 1; i <= 5; i++) {
        for (j = 1; j <= i; j++) {
            printf("* ");
        }
        printf("\n");
    }
}

/* 4. Reverse Integer */
int reverseInteger(int x) {
    int rev = 0;

    while (x != 0) {
        int lastDigit = x % 10;

        if (rev > INT_MAX / 10 || rev < INT_MIN / 10) {
            return 0;
        }

        rev = rev * 10 + lastDigit;
        x = x / 10;
    }

    return rev;
}

int main() {
    int choice, num;

    printf("1. Grade Calculator\n");
    printf("2. Pattern 1\n");
    printf("3. Pattern 2\n");
    printf("4. Reverse Integer\n");
    printf("Enter your choice: ");
    scanf("%d", &choice);

    switch (choice) {
        case 1:
            gradeCalculator();
            break;

        case 2:
            pattern1();
            break;

        case 3:
            pattern2();
            break;

        case 4:
            printf("Enter an integer: ");
            scanf("%d", &num);
            printf("Reversed Integer: %d\n", reverseInteger(num));
            break;

        default:
            printf("Invalid Choice\n");
    }

    return 0;
}
